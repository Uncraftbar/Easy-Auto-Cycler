{
  "schemaVersion": 1,
  "id": "easyautocycler",
  "version": "${version}",
  "name": "Easy Auto Cycler",
  "description": "A client-side mod that adds advanced filtering and automation to trade cycling.",
  "authors": [
    "Uncraftbar"
  ],
  "contact": {
    "sources": "https://github.com/Uncraftbar/Easy-Auto-Cycler"
  },
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.uncraftbar.easyautocycler.EasyAutoCyclerMod"
    ]
  },
  "mixins": [
    "easyautocycler.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.6",
    "minecraft": "~26.2",
    "java": ">=25",
    "fabric-api-base": "*",
    "fabric-key-mapping-api-v1": "*",
    "fabric-networking-api-v1": "*",
    "fabric-resource-loader-v0": "*",
    "fabric-screen-api-v1": "*"
  },
  "suggests": {
    "trade_cycling": "*"
  }
}
